# ============================================
# SUPABASE (SHARED DATABASE)
# ============================================
# IMPORTANT: Use the SAME credentials as FRAX
# Both apps connect to the SAME Supabase database
# Get these from: https://supabase.com/dashboard/project/your-project/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# JWT SECRETS (for custom sessions)
# ============================================
# IMPORTANT: Use the SAME secret as FRAX
JWT_SIGNING_SECRET=your-super-secret-jwt-key-min-32-chars
SESSION_SECRET=your-session-secret-key-here

# ============================================
# APP URLS
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_FRAX_URL=http://localhost:3000

# In production:
# NEXT_PUBLIC_APP_URL=https://company.frax.com
# NEXT_PUBLIC_FRAX_URL=https://frax.com

# ============================================
# EMAIL (Resend) - Optional
# ============================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourcompany.com

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
